{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Example 04 — All Models: Medical Benchmark\n",
    "\n",
    "Compares all five classifiers in the package on medically relevant datasets:\n",
    "breast cancer (binary) and digits (multi-class proxy for imaging tasks).\n",
    "\n",
    "| Model | Key advantage |\n",
    "|---|---|\n",
    "| `FuzzyARTMAP` | Fast, interpretable, baseline |\n",
    "| `FuzzyARTMAP(relevance=r)` | Feature-weighted for unreliable sensors |\n",
    "| `BayesianARTMAP` | Calibrated proba + reduced node proliferation |\n",
    "| `SemiSupervisedARTMAP` | Exploits unlabelled data |\n",
    "| `VotingARTMAP` | Reduces order-sensitivity variance |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.datasets import load_breast_cancer, load_digits\n",
    "from sklearn.model_selection import StratifiedKFold, cross_val_score\n",
    "from sklearn.metrics import classification_report\n",
    "import pandas as pd\n",
    "\n",
    "from fuzzyart import (\n",
    "    FuzzyARTMAP, BayesianARTMAP,\n",
    "    SemiSupervisedARTMAP, VotingARTMAP, BaggingARTMAP\n",
    ")\n",
    "from fuzzyart.preprocessing import normalize"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Breast cancer — calibration & uncertainty"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X_bc, y_bc = load_breast_cancer(return_X_y=True)\n",
    "X_bc = normalize(X_bc)\n",
    "print(f'Breast cancer: {X_bc.shape}, classes: {np.unique(y_bc)}')\n",
    "\n",
    "cv = StratifiedKFold(5, shuffle=True, random_state=42)\n",
    "\n",
    "models = {\n",
    "    'FuzzyARTMAP':    FuzzyARTMAP(epochs=5),\n",
    "    'BayesianARTMAP': BayesianARTMAP(epochs=5),\n",
    "    'VotingARTMAP':   VotingARTMAP(n_voters=7, random_state=0),\n",
    "    'BaggingARTMAP':  BaggingARTMAP(n_estimators=7, random_state=0),\n",
    "}\n",
    "\n",
    "results = {}\n",
    "for name, clf in models.items():\n",
    "    scores = cross_val_score(clf, X_bc, y_bc, cv=cv, scoring='f1_weighted')\n",
    "    results[name] = {'mean': scores.mean(), 'std': scores.std()}\n",
    "    print(f'{name:25s}  F1={scores.mean():.3f} ± {scores.std():.3f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Uncertainty: BayesianARTMAP gives calibrated per-sample entropy\n",
    "clf_ba = BayesianARTMAP(epochs=5).fit(X_bc, y_bc)\n",
    "uncertainty = clf_ba.predict_uncertainty(X_bc)\n",
    "\n",
    "plt.figure(figsize=(7,3))\n",
    "plt.hist(uncertainty[y_bc==0], bins=30, alpha=0.6, label='Malignant')\n",
    "plt.hist(uncertainty[y_bc==1], bins=30, alpha=0.6, label='Benign')\n",
    "plt.xlabel('Predictive entropy'); plt.ylabel('Count')\n",
    "plt.title('BayesianARTMAP — uncertainty by class'); plt.legend()\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Semi-supervised: partial labelling simulation"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "label_fractions = [0.1, 0.2, 0.3, 0.5, 1.0]\n",
    "sup_accs, ss_accs = [], []\n",
    "rng = np.random.default_rng(42)\n",
    "\n",
    "for frac in label_fractions:\n",
    "    mask = rng.random(len(y_bc)) < frac\n",
    "    if mask.sum() < 2:\n",
    "        mask[:5] = True\n",
    "    X_l, y_l = X_bc[mask], y_bc[mask]\n",
    "    X_u = X_bc[~mask]\n",
    "    \n",
    "    sup = BayesianARTMAP(epochs=5).fit(X_l, y_l)\n",
    "    ss  = SemiSupervisedARTMAP(epochs=5, em_iterations=15).fit(X_l, y_l, X_unlabelled=X_u)\n",
    "    \n",
    "    sup_accs.append(np.mean(sup.predict(X_bc) == y_bc))\n",
    "    ss_accs.append(np.mean(ss.predict(X_bc) == y_bc))\n",
    "\n",
    "plt.figure(figsize=(7,4))\n",
    "plt.plot(label_fractions, sup_accs, 'o-', label='Supervised only')\n",
    "plt.plot(label_fractions, ss_accs,  's-', label='Semi-supervised (EM)')\n",
    "plt.xlabel('Fraction labelled'); plt.ylabel('Test accuracy')\n",
    "plt.title('Semi-supervised vs Supervised — Breast Cancer')\n",
    "plt.legend(); plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. Input relevance: down-weight noisy features"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulate noisy sensors: add Gaussian noise to half the features\n",
    "rng = np.random.default_rng(0)\n",
    "X_noisy = X_bc.copy()\n",
    "noisy_feat = rng.choice(X_bc.shape[1], size=X_bc.shape[1]//2, replace=False)\n",
    "X_noisy[:, noisy_feat] += rng.normal(0, 0.1, (len(X_bc), len(noisy_feat)))\n",
    "X_noisy = normalize(np.clip(X_noisy, 0, 1))\n",
    "\n",
    "# Relevance: down-weight noisy features to 0.1, keep clean at 1.0\n",
    "M = X_bc.shape[1]\n",
    "r = np.ones(2*M)  # complement-coded dim\n",
    "r[noisy_feat] = 0.1\n",
    "r[M + noisy_feat] = 0.1  # also down-weight complement of noisy features\n",
    "\n",
    "clf_plain = FuzzyARTMAP(epochs=5)\n",
    "clf_relev = FuzzyARTMAP(epochs=5, relevance=r)\n",
    "\n",
    "cv = StratifiedKFold(5, shuffle=True, random_state=42)\n",
    "s_plain = cross_val_score(clf_plain, X_noisy, y_bc, cv=cv, scoring='f1_weighted')\n",
    "s_relev = cross_val_score(clf_relev, X_noisy, y_bc, cv=cv, scoring='f1_weighted')\n",
    "\n",
    "print(f'Without relevance:  F1 = {s_plain.mean():.3f} ± {s_plain.std():.3f}')\n",
    "print(f'With relevance:     F1 = {s_relev.mean():.3f} ± {s_relev.std():.3f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Node count vs accuracy tradeoff across models"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X_d, y_d = load_digits(return_X_y=True)\n",
    "X_d = normalize(X_d)\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "X_tr, X_te, y_tr, y_te = train_test_split(X_d, y_d, test_size=0.2,\n",
    "                                            stratify=y_d, random_state=0)\n",
    "\n",
    "entries = []\n",
    "for rho in [0.0, 0.2, 0.5, 0.7, 0.9]:\n",
    "    for Model, label in [\n",
    "        (FuzzyARTMAP,    'Fuzzy'),\n",
    "        (BayesianARTMAP, 'Bayesian'),\n",
    "    ]:\n",
    "        clf = Model(rho_baseline=rho, epochs=3).fit(X_tr, y_tr)\n",
    "        acc = np.mean(clf.predict(X_te) == y_te)\n",
    "        entries.append({'model': label, 'rho': rho,\n",
    "                         'nodes': clf.n_committed_, 'accuracy': acc})\n",
    "\n",
    "df = pd.DataFrame(entries)\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "for ax, metric in zip(axes, ['nodes', 'accuracy']):\n",
    "    for model, grp in df.groupby('model'):\n",
    "        ax.plot(grp['rho'], grp[metric], 'o-', label=model)\n",
    "    ax.set_xlabel('rho_baseline'); ax.set_ylabel(metric)\n",
    "    ax.legend()\n",
    "plt.suptitle('Digits — node count and accuracy vs vigilance')\n",
    "plt.tight_layout(); plt.show()"
   ]
  }
 ],
